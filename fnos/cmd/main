#!/bin/bash
FILE_PATH="${TRIM_APPDEST}/docker/docker-compose.yaml"
is_docker_running() {
  local name
  [ -f "$FILE_PATH" ] || return 1
  name=$(grep "container_name" "$FILE_PATH" | head -1 | awk -F ':' '{print $2}' | xargs)
  [ -n "$name" ] || return 1
  docker inspect "$name" 2>/dev/null | grep -q '"Status": "running",'
}
case $1 in
  start)  exit 0 ;;
  stop)   exit 0 ;;
  status) is_docker_running && exit 0 || exit 3 ;;
  *)      exit 1 ;;
esac
